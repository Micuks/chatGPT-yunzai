# OpenClaw
OPENCLAW_ENABLED=true
OPENCLAW_BASE_URL=http://127.0.0.1:18789
OPENCLAW_TOKEN=
OPENCLAW_AUTH_TYPE=bearer
OPENCLAW_AUTH_HEADER=x-openclaw-token
OPENCLAW_AGENT_HOOK_PATH=/hooks/agent
OPENCLAW_SESSION_PATH=/sessions
OPENCLAW_SESSION_MODE=query
OPENCLAW_SESSION_QUERY_KEY=sessionKey
OPENCLAW_WAKE_MODE=now
OPENCLAW_DELIVER=false
OPENCLAW_DELIVER_CHANNEL=
OPENCLAW_DELIVER_TO=
OPENCLAW_POLL_INTERVAL_MS=1000
OPENCLAW_POLL_TIMEOUT_MS=120000
OPENCLAW_SUBMIT_RETRIES=2
OPENCLAW_RETRY_DELAY_MS=500

# Legacy ChatGPT fallback (optional)
LEGACY_CHATGPT_ENABLED=false
OPENAI_API_KEY=
MODEL_NAME=gpt-3.5-turbo
USE_UNOFFICIAL=false
API_ACCESS_TOKEN=
API_REVERSE_PROXY_URL=https://api.pawan.krd/backend-api/conversation

# Runtime
PROXY=
CONCURRENCY_JOBS=1
